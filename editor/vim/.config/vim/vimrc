" vimrc -*- mode: vim; -*-
" Time-stamp: <2026-03-31 19:58:58 Tuesday by zhengyu.li>
" =============================================================================
" Minimal, plugin-free Vim config
" Theme: Dracula (https://draculatheme.com/vim)
"
" Location: ~/.config/vim/vimrc
" Loaded via: VIMINIT=source\ $XDG_CONFIG_HOME/vim/vimrc (set in 00-env.zsh)
" XDG: Manually redirected (Vim predates XDG; VIMINIT bypasses default loader)
"      - Data:  $XDG_DATA_HOME/vim/undo  (~/.local/share/vim/undo)
"      - State: $XDG_STATE_HOME/vim/viminfo  (~/.local/state/vim/viminfo)
" References:
"   1. Vim Options: https://vimdoc.sourceforge.net/htmldoc/options.html
"   2. XDG in Vim: https://wiki.archlinux.org/title/XDG_Base_Directory#Vim
" =============================================================================

" -----------------------------------------------------------------------------
" Baseline
" -----------------------------------------------------------------------------

" Use Vim settings, not Vi
set nocompatible
" Disable modelines
set nomodeline
" Standard encoding
set encoding=utf-8
" Command line history
set history=500
" Sane backspace behavior
set backspace=indent,eol,start

" -----------------------------------------------------------------------------
" XDG Paths
" -----------------------------------------------------------------------------

" Resolve XDG dirs with fallback for non-XDG environments
let s:cfg = ($XDG_CONFIG_HOME != '' ? $XDG_CONFIG_HOME : $HOME . '/.config')
let s:data = ($XDG_DATA_HOME != '' ? $XDG_DATA_HOME : $HOME . '/.local/share')
let s:state = ($XDG_STATE_HOME != ''
             \ ? $XDG_STATE_HOME : $HOME . '/.local/state')

" Redirect runtimepath (VIMINIT skips this; default still points to ~/.vim)
let &runtimepath = s:cfg  . '/vim,'
               \ . s:cfg  . '/vim/after,'
               \ . $VIMRUNTIME

" viminfo → state dir (persistent but not config)
let &viminfofile = s:state . '/vim/viminfo'

" undo → data dir (valuable, keep across reinstalls)
let &undodir = s:data . '/vim/undo'

" Ensure dirs exist (Vim will error on first write if they don't)
for s:dir in [s:state . '/vim', s:data . '/vim/undo']
    if !isdirectory(s:dir) | call mkdir(s:dir, 'p') | endif
endfor

" -----------------------------------------------------------------------------
" Display
" -----------------------------------------------------------------------------

" Absolute line number on current line
set number
" Relative numbers on all other lines
set relativenumber
" Highlight the current line
set cursorline
" Keep 8 lines of context above/below cursor
set scrolloff=8
" Keep 5 columns of context left/right
set sidescrolloff=5
" Soft-wrap long lines at word boundaries
set wrap
" Wrap at word boundaries, not mid-word
set linebreak
" Briefly jump to matching bracket on input
set showmatch
" Show match for 0.2 seconds
set matchtime=2
" Always show status line
set laststatus=2
" Show partial command bottom-right
set showcmd
" Show line/col in status line
set ruler
" Enhanced command-line completion
set wildmenu
" Completion mode: longest match, then full
set wildmode=longest:full,full
" Ignore compiled files and VCS dirs in wildmenu
set wildignore+=*.o,*.obj,*.pyc,*.class,*.swp,*.bak
set wildignore+=*/.git/*,*/.hg/*,*/.svn/*,*/node_modules/*
" Always-on sign column (no layout jitter)
set signcolumn=yes

" -----------------------------------------------------------------------------
" Search
" -----------------------------------------------------------------------------

" Highlight matches as you type
set incsearch
" Keep matches highlighted
set hlsearch
" Case-insensitive by default
set ignorecase
" Case-sensitive if pattern contains uppercase
set smartcase

" Clear search highlight with double-ESC
nnoremap <silent> <Esc><Esc> :nohlsearch<CR>

" -----------------------------------------------------------------------------
" Indentation
" -----------------------------------------------------------------------------

" Use spaces instead of tabs
set expandtab
" Number of spaces per tab character
set tabstop=4
" Spaces inserted by <Tab> key
set softtabstop=4
" Spaces per indentation level
set shiftwidth=4
" Copy indent from current line
set autoindent

" -----------------------------------------------------------------------------
" Files & Persistence
" -----------------------------------------------------------------------------

" Allow hidden buffers
set hidden
" No backup files (use version control)
set nobackup
" No swap files
set noswapfile
" Auto-reload files changed externally
set autoread

" Persistent undo (directory created in XDG section above)
set undofile

" -----------------------------------------------------------------------------
" Behaviour
" -----------------------------------------------------------------------------

" Mouse support in all modes
set mouse=a
" Horizontal splits open below
set splitbelow
" Vertical splits open to the right
set splitright
" Ask instead of failing on unsaved changes
set confirm
" No audio bell; visual bell instead
set noerrorbells visualbell
" Disable visual bell flash
set t_vb=
" Don't redraw during macros (performance)
set lazyredraw
" Faster CursorHold/sign-column refresh
set updatetime=200
" Key sequence timeout (ms)
set timeoutlen=500
" Allow cursor keys to wrap between lines
set whichwrap+=<,>,h,l

" Keep cursor centered when navigating (zz=center, zv=unfold)
nnoremap n     nzzzv
nnoremap N     Nzzzv
nnoremap <C-d> <C-d>zz
nnoremap <C-u> <C-u>zz

" Yank to end of line (consistent with C and D)
nnoremap Y y$

" Stay in visual mode after indenting
vnoremap < <gv
vnoremap > >gv

" Window navigation with Ctrl+hjkl
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" Disable accidental Ex mode entry
nnoremap Q <Nop>

" System clipboard via OSC 52
" Neovim 0.10+ auto-detects OSC 52 from Ghostty terminal capability.
" Vim requires +clipboard compile flag (macOS system Vim has this).
if has('clipboard')
    set clipboard=unnamedplus
endif

" -----------------------------------------------------------------------------
" Auto Commands
" -----------------------------------------------------------------------------

augroup vimrc
    autocmd!

    " Return to last cursor position when reopening a file
    autocmd BufReadPost *
        \ if line("'\"") > 0 && line("'\"") <= line("$") |
        \     execute 'normal! g`"' |
        \ endif

    " Strip trailing whitespace on save (skip binary/diff buffers)
    autocmd BufWritePre *
        \ if &filetype !~# '\v^(diff|xxd)$' |
        \     let b:_view = winsaveview() |
        \     silent! %s/\s\+$//e |
        \     call winrestview(b:_view) |
        \     unlet b:_view |
        \ endif

    " Equalize splits when terminal is resized
    autocmd VimResized * wincmd =

    " Auto-reload file when gaining focus or on idle (external changes)
    autocmd FocusGained,BufEnter * silent! checktime
    autocmd CursorHold,CursorHoldI * silent! checktime

augroup END

" -----------------------------------------------------------------------------
" File Type Overrides
" -----------------------------------------------------------------------------

augroup vimrc_ft
    autocmd!
    " Python: 4 spaces
    autocmd FileType python setlocal tabstop=4 shiftwidth=4
    " Web files: 2 spaces
    autocmd FileType javascript,typescript,json,yaml,html,css,scss
                \ setlocal tabstop=2 softtabstop=2 shiftwidth=2
    " Go: tabs (convention)
    autocmd FileType go setlocal noexpandtab tabstop=4 shiftwidth=4
    " Text files: wrap and spell check
    autocmd FileType markdown,text
                \ setlocal wrap linebreak nolist
    " Git commits: 72 char width, spell check
    autocmd FileType gitcommit
                \ setlocal spell spelllang=en_us textwidth=72 colorcolumn=73
augroup END

" -----------------------------------------------------------------------------
" Status Line
" -----------------------------------------------------------------------------

" mode | filepath [modified][readonly] | filetype | encoding | col:line %

" Must be global (not s:) — statusline %{expr} evaluates outside script scope
function! StatuslineGit() abort
    " Optional: vim-fugitive (https://github.com/tpope/vim-fugitive)
    " Degrades to empty string when plugin is not installed.
    return exists('*FugitiveHead') ? '  ' . FugitiveHead() . ' ' : ''
endfunction

set statusline=
" Current mode
set statusline+=\ %{toupper(mode())}
" Git branch (optional)
set statusline+=%{StatuslineGit()}
" File path
set statusline+=\ %f
" [+] modified, [RO] readonly
set statusline+=\ %m%r
" Right-align separator
set statusline+=%=
" Filetype
set statusline+=\ %y
" Encoding
set statusline+=\ %{&fileencoding?&fileencoding:&encoding}
" Line:column
set statusline+=\ %3l:%-2c
" Percentage
set statusline+=\ %3p%%

" -----------------------------------------------------------------------------
" Syntax Highlighting
" -----------------------------------------------------------------------------

" Disable treesitter — no parsers installed and Neovim 0.12+ ftplugin
" unconditionally calls vim.treesitter.start() which errors without them
if has('nvim')
    lua vim.treesitter.start = function() end
endif

" Enable syntax highlighting (keeps current colors)
syntax enable
" Enable filetype detection, plugins, and indent rules
filetype plugin indent on

" -----------------------------------------------------------------------------
" Dracula Color Theme
" -----------------------------------------------------------------------------

" Palette sourced from https://spec.draculatheme.com
"   bg       #282a36    bg-dark    #21222c    fg          #f8f8f2
"   red      #ff5555    orange     #ffb86c    green       #50fa7b
"   yellow   #f1fa8c    pink       #ff79c6    purple      #bd93f9
"   cyan     #8be9fd    comment    #6272a4    selection   #44475a

set background=dark

" Enable true color support in terminal (24-bit colors)
if has('termguicolors')
    set termguicolors
endif

" Clear existing highlights before applying theme
highlight clear
if exists('syntax_on') | syntax reset | endif
let g:colors_name = 'Dracula'

