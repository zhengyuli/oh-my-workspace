        vim.api.nvim_set_hl(0, "TelescopeMatching", {
          fg = "#50fa7b", bold = true,
        })
        vim.api.nvim_set_hl(0, "TelescopePromptPrefix", {
          fg = "#bd93f9",
        })
        vim.api.nvim_set_hl(0, "TelescopeBorder", {
          fg = "#6272a4",
        })

        -- Keybindings
        local opts = { noremap = true, silent = true }
        vim.keymap.set("n", "<leader>ff", builtin.find_files,
          vim.tbl_extend("force", opts, { desc = "Find files" }))
        vim.keymap.set("n", "<leader>fg", builtin.live_grep,
          vim.tbl_extend("force", opts, { desc = "Live grep" }))
        vim.keymap.set("n", "<leader>fb", builtin.buffers,
          vim.tbl_extend("force", opts, { desc = "Buffers" }))
        vim.keymap.set("n", "<leader>fr", builtin.oldfiles,
          vim.tbl_extend("force", opts, { desc = "Recent files" }))
        vim.keymap.set("n", "<leader>gs", builtin.git_status,
          vim.tbl_extend("force", opts, { desc = "Git status" }))
        vim.keymap.set("n", "<leader>gc", builtin.git_commits,
          vim.tbl_extend("force", opts, { desc = "Git commits" }))
        vim.keymap.set("n", "<leader>fw", builtin.grep_string,
          vim.tbl_extend("force", opts, { desc = "Word under cursor" }))

        -- Expose telescope for FindReferences fallback
        _G.telescope_live_grep_word = function()
          local word = vim.fn.expand("<cword>")
          if word == "" then return end
          builtin.live_grep({ default_text = word })
        end
      end,
    },
    {
      "tpope/vim-fugitive",
      lazy = true,
    },
    {
      "nvim-treesitter/nvim-treesitter",
      -- Plugin only provides :TSInstall commands. Parsers persist on disk;
      -- vim.treesitter.start() (built-in nvim 0.11+ API) handles highlighting
      -- without loading the plugin at runtime.
      cmd = { "TSInstall", "TSInstallSync", "TSUpdate" },
      -- Install parsers once on plugin install/update (LazyVim pattern).
      build = ":TSInstallSync markdown markdown_inline html yaml latex",
    },
    {
      "nvim-tree/nvim-web-devicons",
      lazy = true,
    },
    {
      "MeanderingProgrammer/render-markdown.nvim",
      dependencies = { "nvim-treesitter/nvim-treesitter", "nvim-tree/nvim-web-devicons" },
      ft = "markdown",
    },
  }, {
    root = vim.fn.stdpath("data") .. "/lazy",
    ui = { border = "single" },
    checker = { enabled = false },
  })
EOF

  " Replace grep-based FindReferences with telescope (LSP overrides gr
  " via LspAttach, so this only fires in non-LSP buffers)
  nnoremap <silent> gr :call v:lua.telescope_live_grep_word()<CR>

endif

" Enable syntax highlighting and filetype detection after plugins.
" syntax enable triggers BufReadPost → ftplugins need treesitter parsers;
" filetype plugin indent on enables ftplugin loading. Both must run
" after lazy.nvim has loaded nvim-treesitter.
syntax enable
filetype plugin indent on

" -----------------------------------------------------------------------------
" Automation
" -----------------------------------------------------------------------------

augroup vimrc
  autocmd!

  " --- Cursor Position ---
  " Return to last cursor position when reopening a file
  autocmd BufReadPost *
    \ if line("'\"") > 0 && line("'\"") <= line("$") |
    \   execute 'normal! g`"' |
    \ endif

  " --- Whitespace ---
  " Strip trailing whitespace on save (skip binary/diff buffers)
  autocmd BufWritePre *
    \ if &filetype !~# '\v^(diff|xxd)$' |
    \   let b:_view = winsaveview() |
    \   silent! %s/\s\+$//e |
    \   call winrestview(b:_view) |
    \   unlet b:_view |
    \ endif

  " --- Layout ---
  " Equalize splits when terminal is resized
  autocmd VimResized * wincmd =

  " --- External Reload ---
  " Auto-reload file when gaining focus or on idle (external changes)
  autocmd FocusGained,BufEnter * silent! checktime
  autocmd CursorHold,CursorHoldI * silent! checktime

  " --- Indentation ---
  " Python: 4 spaces
  autocmd FileType python setlocal tabstop=4 shiftwidth=4
  " Web files: 2 spaces
  autocmd FileType javascript,typescript,json,yaml,html,css,scss
    \ setlocal tabstop=2 softtabstop=2 shiftwidth=2
  " Go: tabs (convention)
  autocmd FileType go setlocal noexpandtab tabstop=4 shiftwidth=4

  " --- Text Modes ---
  " Text files: wrap and spell check
  autocmd FileType markdown,text
    \ setlocal wrap linebreak nolist

  " --- Git Commits ---
  " Git commits: 72 char width, spell check
  autocmd FileType gitcommit
    \ setlocal spell spelllang=en_us textwidth=72 colorcolumn=73

  " --- Treesitter ---
  " Built-in nvim 0.11+ API. Parsers installed by nvim-treesitter plugin
  " (:TSInstall). Plugin only loads for install commands; highlighting
  " works via this autocmd without the plugin at runtime.
  " Ref: https://github.com/nvim-treesitter/nvim-treesitter#main-branch
  autocmd FileType markdown,html,yaml,latex
    \ lua vim.treesitter.start(0, vim.bo.filetype)

  " --- Markdown Regex Syntax ---
  " Disable regex syntax (markdown.vim 676ms + html.vim 477ms chain).
  " Treesitter highlighting enabled by FileType autocmd above.
  " ftplugin/markdown.vim still loads (folds, conceal settings intact).
  autocmd FileType markdown setlocal syntax=

augroup END
