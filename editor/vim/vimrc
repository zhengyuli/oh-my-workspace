" Ctrl-I: jump forward (xref-go-forward) — built-in

" -----------------------------------------------------------------------------
" Status Line
" -----------------------------------------------------------------------------

" mode | path [modified][readonly] | type | enc | pos %

" Global scope required — statusline evaluates outside script
function! StatuslineGit() abort
  " Optional: vim-fugitive (https://github.com/tpope/vim-fugitive)
  " Degrades to empty string when plugin is not installed.
  return exists('*FugitiveHead') ? '  ' . FugitiveHead() . ' ' : ''
endfunction

set statusline=
" Current mode
set statusline+=\ %{toupper(mode())}
" Git branch (optional)
set statusline+=%{StatuslineGit()}
" File path
set statusline+=\ %f
" [+] modified, [RO] readonly
set statusline+=\ %m%r
" Right-align separator
set statusline+=%=
" Filetype
set statusline+=\ %y
" Encoding
set statusline+=\ %{&fileencoding?&fileencoding:&encoding}
" Line:column
set statusline+=\ %3l:%-2c
" Percentage
set statusline+=\ %3p%%

