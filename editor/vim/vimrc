" -----------------------------------------------------------------------------
" Display
" -----------------------------------------------------------------------------

" --- Line Numbers ---
" Absolute number on active line aids error message navigation
set number
" Relative numbers enable fast vertical motion (e.g., 5j, 12k)
set relativenumber

" --- Cursor ---
" Cursor line highlights active context during split editing
set cursorline

" --- Scrolling ---
" Keep 8 lines of context above/below cursor
set scrolloff=8
" Keep 5 columns of context left/right
set sidescrolloff=5

" --- Wrapping ---
" Soft-wrap long lines at word boundaries
set wrap
" Wrap at word boundaries, not mid-word
set linebreak

" --- Matching ---
" Briefly jump to matching bracket on input
set showmatch
" Show match for 0.2 seconds
set matchtime=2

" --- Status ---
" Always show status line for consistent split visibility
set laststatus=2
" Partial command display catches incomplete key sequences early
set showcmd
" Fallback ruler when custom statusline is not active
set ruler

" --- Completion ---
" Wildmenu provides navigable tab-completion suggestions
set wildmenu
" Longest:full avoids premature completion; full for disambiguation
set wildmode=longest:full,full
" Ignore artifacts that clutter completions (build outputs, VCS dirs)
set wildignore+=*.o,*.obj,*.pyc,*.class,*.swp,*.bak
set wildignore+=*/.git/*,*/.hg/*,*/.svn/*,*/node_modules/*

" --- Signs ---
" Always-on sign column prevents horizontal jitter on lint/diag signs
set signcolumn=yes

" -----------------------------------------------------------------------------
" Search
" -----------------------------------------------------------------------------

" --- Behavior ---
" Incremental search gives immediate feedback while typing pattern
set incsearch
" Persistent highlights help scan all matches at a glance
set hlsearch

" --- Case ---
" Case-insensitive by default for fewer keystrokes
set ignorecase
" Smart case: uppercase in query signals intentional case-sensitivity
set smartcase

" --- Search Mappings ---
" Clear search highlight with double-ESC
nnoremap <silent> <Esc><Esc> :nohlsearch<CR>

" -----------------------------------------------------------------------------
" Indentation
" -----------------------------------------------------------------------------

" --- Tabs vs Spaces ---
" Spaces instead of tabs (avoids mixed-indent issues)
set expandtab

" --- Width ---
" 4-space width matches Python and most style guides
set tabstop=4
" Tab key inserts spaces consistent with expandtab
set softtabstop=4
" Shiftwidth aligns with tabstop for uniform indentation
set shiftwidth=4

" --- Structure ---
" Autoindent preserves block structure without manual re-indent
set autoindent

" -----------------------------------------------------------------------------
" Files & Persistence
" -----------------------------------------------------------------------------

" --- Buffers ---
" Hidden buffers allow backgrounding unsaved files without closing
set hidden
" No backup files — version control makes them redundant
set nobackup
" No swap — persistent undo and version control suffice
set noswapfile

" --- File Reload ---
" Auto-reload saves a :checktime step when files change externally
set autoread

" --- Undo ---
" Persistent undo (directory created in XDG section above)
set undofile

" -----------------------------------------------------------------------------
" Behavior
" -----------------------------------------------------------------------------

" --- Mouse & Splits ---
" Mouse support in all modes (scrolling, resizing splits in terminal)
set mouse=a
" New splits open below (natural reading flow)
set splitbelow
" Splits open right mirror editor layout convention (file tree left)
set splitright

" --- Safety ---
" Confirm dialog prevents accidental :qa with unsaved changes
set confirm
" Silence audio bell; use visual bell instead (avoids terminal beeps)
set noerrorbells visualbell
" Empty t_vb disables visual bell flash entirely
set t_vb=

" --- Performance ---
" Skip redraw during macros for smoother playback on large files
set lazyredraw
" 1000 ms: no gitsigns-style plugin needs sub-second sign column refresh.
" CursorHold fires checktime — 1s cadence is enough for external reload.
set updatetime=1000

" --- Timing ---
" 1000 ms for leader key sequences (e.g. <Space>ff)
" 50 ms for terminal key codes (<Esc>) to stay responsive
set timeoutlen=1000
set ttimeoutlen=50

" --- Navigation ---
" Wrap cursor keys at line boundaries
set whichwrap+=<,>,h,l

" --- Navigation Mappings ---
" Keep cursor centered when navigating (zz=center, zv=unfold)
nnoremap <silent> n     nzzzv
nnoremap <silent> N     Nzzzv
nnoremap <silent> <C-d> <C-d>zz
nnoremap <silent> <C-u> <C-u>zz

" Yank to end of line (consistent with C and D)
nnoremap <silent> Y y$

" Stay in visual mode after indenting
vnoremap <silent> < <gv
vnoremap <silent> > >gv

" Window navigation with Ctrl+hjkl
nnoremap <silent> <C-h> <C-w>h
nnoremap <silent> <C-j> <C-w>j
nnoremap <silent> <C-k> <C-w>k
nnoremap <silent> <C-l> <C-w>l

" Disable accidental Ex mode entry
nnoremap <silent> Q <Nop>

" System clipboard (macOS pbcopy/pbpaste via +clipboard)
" Neovim 0.10+ can also use OSC 52 from terminals like Ghostty.
if has('clipboard')
  set clipboard=unnamedplus
endif

" -----------------------------------------------------------------------------
" Code Navigation
" -----------------------------------------------------------------------------

" --- Grep ---
if executable('rg')
  set grepprg=rg\ --vimgrep\ --no-heading\ --smart-case
  set grepformat=%f:%l:%c:%m
endif

" --- Shared ---
" Populate quickfix with word occurrences (ripgrep via grepprg)
function! s:FindReferences() abort
  let l:word = expand('<cword>')
  if empty(l:word) | return | endif
  try
    silent execute 'grep! -w ' . shellescape(l:word, 1)
  catch /^Vim\%((\a\+)\)\=:E480/
    cexpr []
  endtry
  cwindow
endfunction

if has('nvim-0.11')
  " --- LSP (Neovim 0.11+) ---
  " Built-in LSP client — no plugin needed. Configures servers that match
  " the Emacs eglot setup (see editor/emacs/lisp/lang/).
  "
  " Keymaps (buffer-local on LspAttach, Emacs xref-like):
  "   gd/gD  definition/declaration    gi  implementation
  "   gr     references                 gy  type definition
  "   ga     code action                K   hover (when keywordprg unset)
  "   <F2>   rename                     <C-s>  signature help (insert)
  "
  " Defaults we do NOT override (set by Neovim 0.11 on LspAttach):
  "   ]d  → next diag    [d  → prev diag
  lua << EOF
  local servers = {
    clangd = {
      cmd = { 'clangd' },
      filetypes = { 'c', 'cpp', 'objc', 'objcpp' },
      root_markers = { 'compile_commands.json', 'compile_flags.txt', '.clangd', '.git' },
    },
    basedpyright = {
      cmd = { 'basedpyright-langserver', '--stdio' },
      filetypes = { 'python' },
      root_markers = {
        'pyproject.toml', 'setup.py', 'setup.cfg',
        'requirements.txt', 'Pipfile', 'pyrightconfig.json', '.git',
      },
      settings = {
        basedpyright = {
          analysis = {
            autoSearchPaths = true,
            useLibraryCodeForTypes = true,
          },
        },
      },
    },
    ts_ls = {
      cmd = { 'typescript-language-server', '--stdio' },
      filetypes = { 'typescript', 'javascript', 'typescriptreact', 'javascriptreact' },
      root_markers = { 'tsconfig.json', 'package.json', '.git' },
    },
    gopls = {
      cmd = { 'gopls' },
      filetypes = { 'go', 'gomod', 'gowork' },
      root_markers = { 'go.mod', 'go.sum', '.git' },
    },
    rust_analyzer = {
      cmd = { 'rust-analyzer' },
      filetypes = { 'rust' },
      root_markers = { 'Cargo.toml', '.git' },
    },
  }

  for name, config in pairs(servers) do
    vim.lsp.config(name, config)
  end
  vim.lsp.enable(vim.tbl_keys(servers))

  -- Delete default gr-prefix keymaps (grr/gri/grn/gra/grt/grx) to avoid
  -- timeout ambiguity with our shorter gr → references binding.
  for _, key in ipairs({ 'grr', 'gri', 'grn', 'gra', 'grt', 'grx' }) do
    pcall(vim.keymap.del, 'n', key)
    pcall(vim.keymap.del, 'x', key)
  end

  local lsp_keymaps = {
    { 'n', 'gd',   vim.lsp.buf.definition },
    { 'n', 'gD',   vim.lsp.buf.declaration },
    { 'n', 'gr',   vim.lsp.buf.references },
    { 'n', 'gi',   vim.lsp.buf.implementation },
    { 'n', 'gy',   vim.lsp.buf.type_definition },
    { 'n', 'ga',   vim.lsp.buf.code_action },
    { 'n', '<F2>', vim.lsp.buf.rename },
  }

  vim.api.nvim_create_autocmd('LspAttach', {
    group = vim.api.nvim_create_augroup('vimrc_lsp', {}),
    callback = function(e)
      local buf = e.buf
      local opts = { buffer = buf, silent = true }

      for _, map in ipairs(lsp_keymaps) do
        vim.keymap.set(map[1], map[2], map[3], opts)
      end

      vim.keymap.set('i', '<C-s>', vim.lsp.buf.signature_help, opts)

      -- Hover: only when keywordprg is unset (respects filetype overrides
      -- like Python's pydoc that set keywordprg after FileType autocmd)
      if vim.bo[buf].keywordprg == '' then
        vim.keymap.set('n', 'K', vim.lsp.buf.hover, opts)
      end
    end,
  })
EOF

else
  " --- Definition & References (Vim) ---
  " ctags :tjump if tags file exists, else built-in gd (local word search)
  function! s:JumpToDefinition() abort
    if filereadable('tags')
      try
        execute 'tjump' expand('<cword>')
        return
      catch /^Vim\%((\a\+)\)\=:E426/
      endtry
    endif
    normal! gd
  endfunction
  nnoremap <silent> gd :call <SID>JumpToDefinition()<CR>
  nnoremap <silent> gr :call <SID>FindReferences()<CR>
endif

