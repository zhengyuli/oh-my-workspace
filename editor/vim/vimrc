" Commentary:
"   Minimal Vim configuration using the Dracula color theme. Vim is a
"   lightweight fallback editor. Neovim adds lazy.nvim for plugin
"   management (telescope, fugitive). XDG paths are redirected
"   manually via VIMINIT since Vim predates the XDG spec.
"
" Loaded via: VIMINIT="set nocp | execute 'source' ..." (set in 00-env.zsh)
" XDG: Manually redirected (Vim predates XDG; VIMINIT bypasses default loader)
"      - Data:  $XDG_DATA_HOME/vim/undo  (~/.local/share/vim/undo)
"      - State: $XDG_STATE_HOME/vim/viminfo  (~/.local/state/vim/viminfo)
"
" References:
"   1. Vim Options: https://vimdoc.sourceforge.net/htmldoc/options.html
"   2. XDG in Vim: https://wiki.archlinux.org/title/XDG_Base_Directory#Vim
" =============================================================================

" -----------------------------------------------------------------------------
" Baseline
" -----------------------------------------------------------------------------

" Avoid Vi compatibility quirks (e.g., limited regex, no autoindent)
set nocompatible
" Security: modelines allow arbitrary commands in file headers
set nomodeline
" --- Provider Hosts ---
" Disable unused provider hosts. pynvim not installed in system python3;
" default probe wastes ~8s on python file open. No plugin in this config
" uses :python3 / :ruby / :perl / :node — all use Lua or LSP RPC.
let g:loaded_python3_provider = 0
let g:loaded_ruby_provider = 0
let g:loaded_perl_provider = 0
let g:loaded_node_provider = 0
" UTF-8 required for multi-byte characters and modern tooling
set encoding=utf-8
" Longer history aids command recall across sessions
set history=500
" Sane backspace behavior
set backspace=indent,eol,start

" -----------------------------------------------------------------------------
" XDG Paths
" -----------------------------------------------------------------------------

" Resolve XDG dirs with fallback for non-XDG environments
let s:cfg = ($XDG_CONFIG_HOME != '' ? $XDG_CONFIG_HOME : $HOME . '/.config')
let s:data = ($XDG_DATA_HOME != '' ? $XDG_DATA_HOME : $HOME . '/.local/share')
let s:state = ($XDG_STATE_HOME != ''
             \ ? $XDG_STATE_HOME : $HOME . '/.local/state')

" Redirect runtimepath (VIMINIT skips default ~/.vim)
let &runtimepath = s:cfg  . '/vim,'
               \ . s:cfg  . '/vim/after,'
               \ . $VIMRUNTIME

" viminfo → state dir (persistent but not config)
let &viminfofile = s:state . '/vim/viminfo'

" undo → data dir (valuable, keep across reinstalls)
let &undodir = s:data . '/vim/undo'

" Ensure dirs exist (Vim will error on first write if they don't)
for s:dir in [s:state . '/vim', s:data . '/vim/undo']
  if !isdirectory(s:dir) | call mkdir(s:dir, 'p') | endif
endfor

