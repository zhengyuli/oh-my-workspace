# config -*- mode: conf; -*-
# Time-stamp: <2026-03-21 00:00:00 Friday by zhengyu.li>
# =============================================================================
# Ghostty Terminal Configuration
#
# Location: ~/.config/ghostty/config
# XDG: Native support (reads $XDG_CONFIG_HOME/ghostty/config by default)
# References:
#   1. Config Docs:   https://ghostty.org/docs/config
#   2. Option Ref:    https://ghostty.org/docs/config/reference
#   3. Keybind Docs:  https://ghostty.org/docs/config/keybind
# =============================================================================

# -----------------------------------------------------------------------------
# Theme
# -----------------------------------------------------------------------------
theme = Dracula

# -----------------------------------------------------------------------------
# Fonts
# -----------------------------------------------------------------------------
font-family = "SauceCodePro Nerd Font"
font-size = 15
font-thicken = true

# OpenType features: contextual alternates, ligatures, stylistic set 13
font-feature = calt
font-feature = liga
font-feature = ss13

# Shaping & weight rendering
font-shaping-break = cursor
bold-is-bright = true

# -----------------------------------------------------------------------------
# Cursor
# -----------------------------------------------------------------------------
cursor-style = bar
cursor-style-blink = false
adjust-cursor-thickness = 10

# -----------------------------------------------------------------------------
# Window & Appearance
# -----------------------------------------------------------------------------
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true

background-opacity = 0.98
background-blur = true
background-blur-radius = 20

# "tabs" integrates the tab bar directly into the titlebar — more compact than
# "transparent" which stacks a separate native tab bar on top of the titlebar.
# Multiple related macOS bugs were fixed in Ghostty 1.2.3; now stable.
macos-titlebar-style = tabs
macos-titlebar-proxy-icon = hidden
macos-window-shadow = true

# -----------------------------------------------------------------------------
# Rendering
# -----------------------------------------------------------------------------
window-vsync = true
alpha-blending = linear-corrected
minimum-contrast = 1.1
window-colorspace = display-p3

# -----------------------------------------------------------------------------
# Shell Integration
# -----------------------------------------------------------------------------
shell-integration = detect
shell-integration-features = cursor,sudo,title

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
# Requires shell integration (OSC 133) — already enabled above.
# Covers long-running shell commands (builds, tests, etc.) when Ghostty is
# unfocused. 
desktop-notifications = true
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s

# -----------------------------------------------------------------------------
# Scrollback & Selection
# -----------------------------------------------------------------------------
# Increased from 10000: Claude Code sessions generate substantial output.
scrollback-limit = 50000
copy-on-select = clipboard
selection-clear-on-typing = true

# -----------------------------------------------------------------------------
# URL Handling
# -----------------------------------------------------------------------------
link-url = true
link-previews = true

# -----------------------------------------------------------------------------
# Clipboard
# -----------------------------------------------------------------------------
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# -----------------------------------------------------------------------------
# Mouse
# -----------------------------------------------------------------------------
mouse-hide-while-typing = true

# -----------------------------------------------------------------------------
# Terminal
# -----------------------------------------------------------------------------
term = xterm-ghostty
grapheme-width-method = unicode
bell-features = system

# -----------------------------------------------------------------------------
# Multi-surface Behavior
# -----------------------------------------------------------------------------
window-inherit-working-directory = true
window-inherit-font-size = true
window-new-tab-position = current
window-save-state = always
confirm-close-surface = true
unfocused-split-opacity = 0.6

# -----------------------------------------------------------------------------
# Quick Terminal
# -----------------------------------------------------------------------------
quick-terminal-position = top
quick-terminal-screen = main
quick-terminal-animation-duration = 0.2

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
macos-option-as-alt = left
macos-icon = retro
auto-update = check

# -----------------------------------------------------------------------------
# Keybindings
# -----------------------------------------------------------------------------
# Config
keybind = super+shift+comma=reload_config

# Splits
keybind = super+shift+j=goto_split:next

# Tabs — create & cycle
keybind = super+t=new_tab
keybind = super+shift+n=next_tab
keybind = super+shift+p=previous_tab

# Tabs — reorder
keybind = super+shift+left=move_tab:-1
keybind = super+shift+right=move_tab:1

# Quick Terminal
keybind = super+shift+l=toggle_quick_terminal

# Passthrough — let zsh handle these directly
keybind = ctrl+l=unbind

# -----------------------------------------------------------------------------
# Local overrides  (optional, not tracked by version control)
# -----------------------------------------------------------------------------
config-file = ?config.local