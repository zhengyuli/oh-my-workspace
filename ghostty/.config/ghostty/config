# config -*- mode: conf; -*-
# Time-stamp: <2026-03-17 00:00:00 Tuesday by zhengyu.li>
# =============================================================================
# Ghostty Terminal Configuration
#
# Location: ~/.config/ghostty/config
# XDG: Native support (reads $XDG_CONFIG_HOME/ghostty/config by default)
# References:
#   1. Config Docs:   https://ghostty.org/docs/config
#   2. Option Ref:    https://ghostty.org/docs/config/reference
#   3. Keybind Docs:  https://ghostty.org/docs/config/keybind
# =============================================================================

# -----------------------------------------------------------------------------
# Theme
# -----------------------------------------------------------------------------
theme = catppuccin mocha

# -----------------------------------------------------------------------------
# Auto-update
# -----------------------------------------------------------------------------
auto-update = check

# -----------------------------------------------------------------------------
# Fonts
# -----------------------------------------------------------------------------
font-family = "SauceCodePro Nerd Font"
font-size = 15
font-thicken = true
font-shaping-break = cursor

# -----------------------------------------------------------------------------
# Cursor
# -----------------------------------------------------------------------------
cursor-style = bar
cursor-style-blink = false
adjust-cursor-thickness = 10

# -----------------------------------------------------------------------------
# Window & Appearance
# -----------------------------------------------------------------------------
title = " "

window-padding-x = 8
window-padding-y = 8
window-padding-balance = true

background-opacity = 0.95
background-blur-radius = 20

alpha-blending = linear-corrected
minimum-contrast = 1.1

unfocused-split-opacity = 0.6

macos-titlebar-style = hidden
macos-titlebar-proxy-icon = hidden
macos-window-shadow = true

# -----------------------------------------------------------------------------
# Shell Integration
# -----------------------------------------------------------------------------
shell-integration = detect
shell-integration-features = cursor,sudo,title

# -----------------------------------------------------------------------------
# Scrollback & Selection
# -----------------------------------------------------------------------------
scrollback-limit = 10000
copy-on-select = clipboard
selection-clear-on-typing = true

# -----------------------------------------------------------------------------
# URL Handling
# -----------------------------------------------------------------------------
link-url = true

# -----------------------------------------------------------------------------
# Clipboard
# -----------------------------------------------------------------------------
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# -----------------------------------------------------------------------------
# Mouse
# -----------------------------------------------------------------------------
mouse-hide-while-typing = true

# -----------------------------------------------------------------------------
# Terminal Compatibility
# -----------------------------------------------------------------------------
term = xterm-ghostty
grapheme-width-method = unicode

# -----------------------------------------------------------------------------
# Bell
# -----------------------------------------------------------------------------
bell-features = system

# -----------------------------------------------------------------------------
# Multi-surface Behaviour
# -----------------------------------------------------------------------------
window-inherit-working-directory = true
window-inherit-font-size = true
confirm-close-surface = true

# -----------------------------------------------------------------------------
# macOS-specific
# -----------------------------------------------------------------------------
macos-option-as-alt = left
macos-icon = chalkboard

# -----------------------------------------------------------------------------
# Keybindings
# -----------------------------------------------------------------------------
# Splits
keybind = super+shift+j=goto_split:next

# Tabs
keybind = super+shift+n=next_tab
keybind = super+shift+p=previous_tab

# Scrollback
keybind = ctrl+l=clear_screen

# -----------------------------------------------------------------------------
# Local overrides  (optional, not tracked by version control)
# -----------------------------------------------------------------------------
config-file = ?config.local
