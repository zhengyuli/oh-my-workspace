#!/usr/bin/env bash
echo "$*" >> "${MOCK_CURL_LOG:-/dev/null}"
if [[ -f "${MOCK_CURL_FAIL_FILE:-}" ]]; then
  count=$(cat "${MOCK_CURL_FAIL_FILE}")
  if (( count > 0 )); then
    echo $(( count - 1 )) > "${MOCK_CURL_FAIL_FILE}"
    exit 1
  fi
fi
local_output=""
for arg in "$@"; do
  if [[ "${prev_arg:-}" == "--output" ]]; then
    local_output="${arg}"
  fi
  prev_arg="${arg}"
done
if [[ -n "${local_output}" ]]; then
  printf '#!/usr/bin/env bash\nexit 0\n' > "${local_output}"
fi
exit 0
