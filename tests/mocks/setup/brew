#!/usr/bin/env bash
echo "$*" >> "${MOCK_BREW_LOG:-/dev/null}"
case "$1" in
  --version) printf 'Homebrew %s\n' "${MOCK_BREW_VERSION:-4.4.0}" ;;
  shellenv) printf 'export PATH="/opt/homebrew/bin:$PATH"\n' ;;
  bundle) exit "${MOCK_BREW_BUNDLE_RC:-0}" ;;
  install) exit "${MOCK_BREW_INSTALL_RC:-0}" ;;
  *) exit 0 ;;
esac
