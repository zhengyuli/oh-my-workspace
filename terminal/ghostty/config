# -----------------------------------------------------------------------------
# Theme
# -----------------------------------------------------------------------------

theme = Dracula

# -----------------------------------------------------------------------------
# Fonts
# -----------------------------------------------------------------------------

font-family = "SauceCodePro Nerd Font"
font-size = 15
font-thicken = true

# --- OpenType Features ---
font-feature = calt
font-feature = liga
font-feature = ss13

# --- Shaping ---
font-shaping-break = cursor

# -----------------------------------------------------------------------------
# Cursor
# -----------------------------------------------------------------------------

cursor-style = bar
# No blinking — reduces visual noise and distraction
cursor-style-blink = false
# Bright blue for high visibility against dark backgrounds
cursor-color = #00BFFF
# 0.8 opacity keeps cursor visible in active split while dimmed inactive split
# (via unfocused-split-opacity overlay) remains clearly less prominent
cursor-opacity = 0.8
# 12px thickness for comfortable visibility of the bar cursor
adjust-cursor-thickness = 12

# -----------------------------------------------------------------------------
# Window & Appearance
# -----------------------------------------------------------------------------

window-padding-x = 8
window-padding-y = 8
window-padding-balance = true

background-opacity = 0.98
background-blur-radius = 20

# "Tabs" embeds the tab bar in the titlebar; more compact than "transparent"
# which stacks a separate native tab bar on top of the titlebar.
# macOS titlebar bugs were fixed in Ghostty 1.2.3; now stable.
macos-titlebar-style = tabs
# Hide CWD proxy icon (only effective with native titlebar; tabs style has no
# proxy icon, but this future-proofs if style changes)
macos-titlebar-proxy-icon = hidden

# -----------------------------------------------------------------------------
# Rendering
# -----------------------------------------------------------------------------

window-vsync = true
# Minimum contrast ratio (1-21) ensures readable text on colored backgrounds
minimum-contrast = 1.1
# Use Display P3 color space for wider gamut on supported displays
window-colorspace = display-p3

# -----------------------------------------------------------------------------
# Shell Integration
# -----------------------------------------------------------------------------

shell-integration = detect
shell-integration-features = cursor,sudo,title

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------

# Requires shell integration (OSC 133) — already enabled above.
# Covers long-running shell commands (builds, tests, etc.) when Ghostty is
# unfocused.
notify-on-command-finish = unfocused
# Suppress terminal bell; use desktop notification only (less disruptive)
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s

# -----------------------------------------------------------------------------
# Scrollback
# -----------------------------------------------------------------------------

# Increased from 10000: Claude Code sessions generate substantial output.
scrollback-limit = 50000

# -----------------------------------------------------------------------------
# Selection & Clipboard
# -----------------------------------------------------------------------------

# Copy to both selection and system clipboard for middle-click and Cmd+V
copy-on-select = clipboard
# Clear selection on typing to avoid stale highlights interfering with input
# NOTE: valid option since Ghostty 1.1+; default is true but set explicitly
selection-clear-on-typing = true

# -----------------------------------------------------------------------------
# URL Handling
# -----------------------------------------------------------------------------

# Detect and open URLs on hover (Cmd+click on macOS)
link-url = true
# Show a popup preview of the URL content before opening
link-previews = true

# -----------------------------------------------------------------------------
# Clipboard
# -----------------------------------------------------------------------------

# Allow reads/writes without prompting (personal machine, no secrets risk)
clipboard-read = allow
clipboard-write = allow
# Trim trailing whitespace on copy to avoid invisible characters
clipboard-trim-trailing-spaces = true
# Warn before pasting multi-line content that may contain commands
clipboard-paste-protection = true

# -----------------------------------------------------------------------------
# Mouse
# -----------------------------------------------------------------------------

mouse-hide-while-typing = true

# -----------------------------------------------------------------------------
# Terminal
# -----------------------------------------------------------------------------

# Report as xterm-ghostty for accurate TERM detection by remote hosts
term = xterm-ghostty
# Unicode standard for grapheme width (correct for emoji, CJK, etc.)
grapheme-width-method = unicode
# Route bell to system notification (macOS)
bell-features = system

# -----------------------------------------------------------------------------
# Multi-Surface Behavior
# -----------------------------------------------------------------------------

# New windows/tabs inherit CWD and font size from the previously focused window
window-inherit-working-directory = true
window-inherit-font-size = true
# Open new tabs adjacent to the current tab (not at the end)
window-new-tab-position = current
# Never persist window layout (position, size, tabs, splits) across restarts
window-save-state = never
# Confirm before closing any terminal surface to prevent accidental loss
confirm-close-surface = true
# Dim unfocused splits to 60% opacity for visual focus distinction
unfocused-split-opacity = 0.6

# -----------------------------------------------------------------------------
# Quick Terminal
# -----------------------------------------------------------------------------

# Slide-down overlay from the top of the main screen (like macOS Spotlight)
quick-terminal-position = top
quick-terminal-screen = mouse
# 40% screen height, full width (secondary axis for top position)
quick-terminal-size = 40%
# 0.2s animation for snappy feel without being jarring
quick-terminal-animation-duration = 0.2

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------

# Treat left Option as Alt key (needed for Emacs-style keybindings in terminal)
macos-option-as-alt = left
# Retro-styled app icon in dock (official Ghostty variant by artists)
macos-icon = retro

# -----------------------------------------------------------------------------
# Updates
# -----------------------------------------------------------------------------

# Check for updates periodically and notify (macOS only, via Sparkle)
auto-update = check

# -----------------------------------------------------------------------------
# Keybindings
# -----------------------------------------------------------------------------

# --- Config ---
keybind = super+shift+comma=reload_config

# --- Splits ---
keybind = super+shift+j=goto_split:next

# --- Tabs: Create & Cycle ---
keybind = super+t=new_tab
keybind = super+shift+n=next_tab
keybind = super+shift+p=previous_tab

# --- Tabs: Reorder ---
keybind = super+shift+left=move_tab:-1
keybind = super+shift+right=move_tab:1

# --- Quick Terminal ---
keybind = super+shift+l=toggle_quick_terminal

# --- Passthrough ---
# Let zsh handle these directly
keybind = ctrl+l=unbind

# -----------------------------------------------------------------------------
# Local Overrides
# -----------------------------------------------------------------------------

config-file = ?config.local
