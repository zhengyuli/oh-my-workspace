# -----------------------------------------------------------------------------
# Theme
# -----------------------------------------------------------------------------

# Match Ghostty's Dracula theme for visual consistency
--theme="Dracula"

# -----------------------------------------------------------------------------
# Display
# -----------------------------------------------------------------------------

# Show line numbers and git change markers; omit header/grid/snip
--style="numbers,changes"

# Allow italic escape sequences (e.g., comments in Dracula theme)
--italic-text=always

# -----------------------------------------------------------------------------
# Pager
# -----------------------------------------------------------------------------

# -F exits if content fits one screen; -R passes ANSI colors through
--pager="less -FR"

# -----------------------------------------------------------------------------
# Syntax Mapping
# -----------------------------------------------------------------------------

# Treat .conf files as INI for syntax highlighting
--map-syntax "*.conf:INI"
