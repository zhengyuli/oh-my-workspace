# config -*- mode: gitconfig; -*-
# Time-stamp: <2026-03-28 00:00:00 Saturday by zhengyu.li>
# =============================================================================
# Git Configuration
#
# XDG: Native support (GIT_CONFIG_GLOBAL or default ~/.config/git/config)
#      - Local override: ~/.config/git/config.local (identity, proxy, etc.)
# References:
#   1. Git Config Docs: https://git-scm.com/docs/git-config
#   2. Julia Evans: https://jvns.ca/blog/2024/02/16/popular-git-config-options/
# Note: Put personal user info (name, email) in ~/.config/git/config.local
# =============================================================================

# -----------------------------------------------------------------------------
# User (override in ~/.config/git/config.local)
# -----------------------------------------------------------------------------
# Identity intentionally omitted here; set machine-specific config in .local

[include]
    path = ~/.config/git/config.local

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------
[core]
    # Use delta for syntax-highlighted, line-numbered diff output
    pager = delta
    # Convert CRLF to LF on commit (Unix-style line endings)
    autocrlf = input
    # Display non-ASCII filenames correctly (e.g., Chinese characters)
    quotepath = false
    # Require exact case matching for reliable cross-platform behavior
    ignorecase = false
    # Normalize Unicode filenames on macOS for consistency
    precomposeunicode = true
    excludesfile = ~/.config/git/ignore
    # Enable parallel index loading for better performance
    preloadindex = true
    # Cache untracked files for faster git status
    untrackedCache = true
    # macOS FSMonitor daemon for faster status (requires Git 2.37+)
    fsmonitor = true

# -----------------------------------------------------------------------------
# Interactive Settings
# -----------------------------------------------------------------------------
[interactive]
    # Pipe interactive diff through delta for consistent highlighting
    diffFilter = delta --color-only

# -----------------------------------------------------------------------------
# Delta Settings
# -----------------------------------------------------------------------------
# https://github.com/dandavison/delta
[delta]
    # Enable n/N keybindings to navigate between diff hunks
    navigate = true
    light = false
    line-numbers = true
    side-by-side = false

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
[feature]
    # Optimize for repositories with many files
    manyFiles = true

# -----------------------------------------------------------------------------
# Help Settings
# -----------------------------------------------------------------------------
[help]
    # Confirm before running autocorrected command (Git 2.36+)
    autocorrect = prompt

# -----------------------------------------------------------------------------
# Init Settings
# -----------------------------------------------------------------------------
[init]
    defaultBranch = main

# -----------------------------------------------------------------------------
# Alias Definitions
# -----------------------------------------------------------------------------
[alias]
    # Set user identity in config.local (git set-user "Name" "email")
    set-user = "!f(){ g=~/.config/git/config.local;git config -f \"$g\" user.name \"$1\";git config -f \"$g\" user.email \"$2\";};f"
    # Show current user identity
    whoami = "!git config user.name && git config user.email"

# -----------------------------------------------------------------------------
# Color Settings
# -----------------------------------------------------------------------------
[color]
    # Colorize output when writing to terminal
    ui = auto

# -----------------------------------------------------------------------------
# Branch Settings
# -----------------------------------------------------------------------------
[branch]
    # Sort branches by most recent commit (newest first)
    sort = -committerdate

# -----------------------------------------------------------------------------
# Tag Settings
# -----------------------------------------------------------------------------
[tag]
    # Sort tags by semantic version (descending)
    sort = -version:refname

# -----------------------------------------------------------------------------
# Column Settings
# -----------------------------------------------------------------------------
[column]
    # Display branch/tag lists in columns when space allows
    ui = auto

# -----------------------------------------------------------------------------
# Push & Pull Settings
# -----------------------------------------------------------------------------
[push]
    # Only push current branch to its upstream (safest default)
    default = simple
    # Automatically set upstream when pushing a new branch
    autoSetupRemote = true

[pull]
    # Rebase instead of merge for cleaner history
    rebase = true

# -----------------------------------------------------------------------------
# Fetch Settings
# -----------------------------------------------------------------------------
[fetch]
    # Remove stale remote-tracking branches
    prune = true
    # Verify object integrity on fetch (security)
    fsckobjects = true

# -----------------------------------------------------------------------------
# Rebase Settings
# -----------------------------------------------------------------------------
[rebase]
    # Auto-squash fixup!/squash! commits during interactive rebase
    autosquash = true
    # Stash and restore uncommitted changes around rebase
    autostash = true
    # Auto-update stacked branch refs (Git 2.38+)
    updateRefs = true

# -----------------------------------------------------------------------------
# Rerere (Reuse Recorded Resolution)
# -----------------------------------------------------------------------------
[rerere]
    # Remember and replay conflict resolutions
    enabled = true

# -----------------------------------------------------------------------------
# Commit Settings
# -----------------------------------------------------------------------------
[commit]
    # Show diff in commit message editor template
    verbose = true

# -----------------------------------------------------------------------------
# Diff Settings
# -----------------------------------------------------------------------------
[diff]
    # Use histogram algorithm (better at handling code moves)
    algorithm = histogram
    # Detect both renames and copies
    renames = copies
    # Highlight relocated code blocks distinctly
    colorMoved = default
    # Use i/w/c/o prefixes instead of a/b
    mnemonicPrefix = true

# --- Language-specific hunk headers ---
[diff "golang"]
    # Go function detection for better diff hunk headers
    xfuncname = "^func[[:space:]]+\\([^)]+\\)[[:space:]]+([^_(]+)"

# -----------------------------------------------------------------------------
# Merge Settings
# -----------------------------------------------------------------------------
[merge]
    # Show base context in conflicts (Git 2.35+)
    conflictstyle = zdiff3
    tool = nvimdiff

[mergetool]
    prompt = false

# -----------------------------------------------------------------------------
# Transfer Settings (Security)
# -----------------------------------------------------------------------------
[transfer]
    # Verify object integrity during transfer
    fsckobjects = true

# -----------------------------------------------------------------------------
# Credential Helper (macOS)
# -----------------------------------------------------------------------------
[credential]
    helper = osxkeychain
