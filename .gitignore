# Emacs compiled files
*.elc
emacs/*.elc
emacs/lisp/*.elc

# Emacs lock files
.#*

# Emacs auto-save files
*~
\#*\#

# Test directory (not tracked by git)
test/
tests/
emacs/test/
emacs/tests/

# Test artifacts
*.test.elc
*-test-report-*.txt

# IDE files
.idea/
.vscode/
.claude/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Git worktrees
.worktrees/
docs/

# Zsh local config (machine-specific, never commit)
zsh/.config/zsh/conf.d/99-local.zsh

zsh/.config/zsh/cache/

# Git local config (machine-specific, never commit)
git/.config/git/config.local

# Stow internal (stow itself manages these)
.stow-local-ignore
