# .gitignore -*- mode: gitignore; -*-
# Time-stamp: <2026-03-27 00:00:00 Thursday by zhengyu.li>
# =============================================================================
# Git Ignore Patterns - oh-my-workspace
#
# Note: Patterns follow gitignore(5) specification
#
# References:
#   1. gitignore docs: https://git-scm.com/docs/gitignore
#
# Organization: Broad patterns (**/pattern) catch files wherever they appear
# Rationale: Tools may write cache/data to wrong locations (e.g., ~/.config/xxx/
#            instead of XDG directories). Broad patterns protect against this.
# =============================================================================

# -----------------------------------------------------------------------------
# Editor / IDE Files
# -----------------------------------------------------------------------------
# Catch editor-generated files wherever they appear in the repository

# Emacs
# Compiled elisp, auto-saves, backups, package cache
*.elc
.#*
*~
\#*\#
**/auto-save-list/
**/elpa/
**/url/
**/.emacs.desktop
**/.emacs.desktop.lock
**/desktop/
**/projects

# VS Code
.vscode/

# Vim
# Swap files, undo history, sessions, views
*.swp
*.swo
**/viminfo
**/undo/
**/session/
**/view/
**/spell/

# Claude Code (track rules and project settings, ignore local settings)
.claude/settings.local.json

# OpenAI Codex
.codex/

# omc
.omc/

# -----------------------------------------------------------------------------
# Shell Files
# -----------------------------------------------------------------------------
# Catch completion caches, history, compiled scripts wherever they appear

# Zsh
**/.zcompdump
**/.zcompdump.*
**/*.zwc
**/history
**/.zhistory
**/.zsh_history
**/zinit/
**/conf.d/99-local.zsh

# -----------------------------------------------------------------------------
# Tool Files
# -----------------------------------------------------------------------------
# Tool-specific cache, state, and local configuration files

# GitHub Copilot
.github/

# Git / Ghostty (both use config.local for machine-specific overrides)
**/config.local
**/credentials

# Yazi
**/plugins/
**/flavors/

# -----------------------------------------------------------------------------
# Language Runtime Files
# -----------------------------------------------------------------------------
# Cache, build artifacts, dependency directories

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist-info/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
*.cover

# TypeScript/Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# Build artifacts
dist/
build/
*.js.map
*.d.ts.map

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------

test/
tests/
*.test.elc
*-test-report-*.txt

# -----------------------------------------------------------------------------
# Operating Systems
# -----------------------------------------------------------------------------

# macOS
.DS_Store

# Windows
Thumbs.db

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------

.worktrees/
.claude/worktrees/

# -----------------------------------------------------------------------------
# Cross-Cutting Patterns
# -----------------------------------------------------------------------------
# Only patterns that are truly universal (not already covered above)

# Cache directories (generic)
**/.cache/

# Backup files (generic)
**/*.bak
**/*.backup
**/*.orig

# (Editor lock files already covered by .#* and \#*\# in Editor/IDE section —
# gitignore patterns without / match at any directory depth per gitignore(5).)

# Local and secret config overrides (TOML/YAML split-file strategy)
*.local.toml
*.local.yml
*.local.yaml
*_secret.toml
*_secret.yml
*_secret.yaml
.gstack/
