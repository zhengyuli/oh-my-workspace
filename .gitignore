# .gitignore
# Time-stamp: <2026-03-17 00:00:00 Tuesday by zhengyu.li>
# =============================================================================
# Git Ignore Patterns - oh-my-workspace
#
# Location: $WORKSPACE_DIR/.gitignore (repository root)
# Note: Patterns follow gitignore(5) specification
# =============================================================================

# -----------------------------------------------------------------------------
# Editor / IDE Files
# -----------------------------------------------------------------------------

# Emacs
*.elc
.#*
*~
\#*\#
emacs/.config/emacs/auto-save-list/
emacs/.config/emacs/elpa/
emacs/.config/emacs/url/
emacs/.config/emacs/.emacs.desktop
emacs/.config/emacs/.emacs.desktop.lock
emacs/.config/emacs/desktop/
emacs/.config/emacs/projects
emacs/.config/emacs/.cache/

# VS Code
.vscode/

# Vim
*.swp
*.swo
vim/.config/vim/viminfo
vim/.config/vim/undo/
vim/.config/vim/session/
vim/.config/vim/view/

# Claude Code (track rules, ignore local settings)
.claude/settings.json
.claude/settings.local.json

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------

test/
tests/
*.test.elc
*-test-report-*.txt

# -----------------------------------------------------------------------------
# Operating Systems
# -----------------------------------------------------------------------------

# macOS
.DS_Store

# Windows
Thumbs.db

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------

.worktrees/
.claude/worktrees/

# -----------------------------------------------------------------------------
# Local / Machine-Specific Files
# -----------------------------------------------------------------------------

# Zsh
zsh/.config/zsh/conf.d/99-local.zsh
zsh/.config/zsh/.zcompdump
zsh/.config/zsh/.zcompdump.*
zsh/.config/zsh/cache/
zsh/.config/zsh/history
zsh/.config/zsh/.zhistory
zsh/.config/zsh/zinit/
zsh/.config/zsh/*.zwc
zsh/.config/zsh/**/*.zwc

# Git
git/.config/git/config.local
git/.config/git/credentials

# Ghostty
ghostty/.config/ghostty/config.local

# Yazi
tool/yazi/.config/yazi/plugins/

# Vim (machine-specific)
vim/.config/vim/**/*.swp
vim/.config/vim/**/*.swo
vim/.config/vim/**/*.bak
vim/.config/vim/**/*~

# -----------------------------------------------------------------------------
# General Patterns
# -----------------------------------------------------------------------------
# Catch-all patterns for cache, backup, and temporary files

# Cache directories and files
**/.cache/
**/*.cache
**/*.zwc
**/*.elc
**/*.pyc
**/*.pyo

# Lock files
**/.#*
**/#*#

# Backup files
**/*~
**/*.bak
**/*.backup
**/*.orig