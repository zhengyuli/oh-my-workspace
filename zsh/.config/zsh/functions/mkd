# mkd
# Time-stamp: <2026-03-19 21:00:00 Thursday by zhengyu.li>
# =============================================================================
# Create a new directory and enter it
#
# Arguments:
#   $@ - Directory path(s) to create
#
# Examples:
#   mkd newdir
#   mkd path/to/nested/dir
# =============================================================================
mkd() {
  mkdir -p "$@" && cd "${_}"
}
