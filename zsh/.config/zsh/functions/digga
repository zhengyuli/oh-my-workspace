# digga
# Time-stamp: <2026-03-19 21:00:00 Thursday by zhengyu.li>
# =============================================================================
# Run dig with useful formatting
#
# Arguments:
#   $1 - Domain name
#
# Dependencies: dig
#
# Examples:
#   digga example.com
#   digga google.com
# =============================================================================
digga() {
  dig +nocmd "$1" any +multiline +noall +answer
}
