# functions/gitignore
# Fetch .gitignore templates from gitignore.io.
#
# Usage:
#   gitignore python node macos >> .gitignore
#   gitignore list              -- list all available templates
gitignore() {
  if [[ $# -eq 0 ]]; then
    echo "Usage: gitignore <language/tool> [...]"
    echo "       gitignore list"
    return 1
  fi

  local api="https://www.toptal.com/developers/gitignore/api"

  if [[ "$1" == "list" ]]; then
    curl -sL "${api}/list" | tr ',' '\n' | sort | column
    return
  fi

  local joined
  joined="$(echo "$@" | tr ' ' ',')"
  curl -sL "${api}/${joined}"
}
