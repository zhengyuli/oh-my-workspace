# =============================================================================
# Start an HTTP server from a directory
#
# Arguments:
#   $1 - Port number (optional, defaults to 8000)
#
# Dependencies: python3
#
# Examples:
#   serve
#   serve 3000
#   serve 8080
# =============================================================================
serve() {
  local port="${1:-8000}"
  if [[ "$OSTYPE" == darwin* ]]; then
    sleep 1 && open "http://localhost:${port}/" &
  fi
  python3 -m http.server "$port"
}
