# git-branches-by-date
# Time-stamp: <2026-03-19 21:00:00 Thursday by zhengyu.li>
# =============================================================================
# List branches sorted by last commit date
#
# Arguments: None
#
# Examples:
#   git-branches-by-date
# =============================================================================
git-branches-by-date() {
  git for-each-ref --sort=committerdate --format='%(refname:short) %(committerdate:short)' refs/heads/
}
